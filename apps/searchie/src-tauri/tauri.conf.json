{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "searchie",
  "version": "0.1.4",
  "identifier": "com.ardev.searchie",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "searchie",
        "width": 800,
        "height": 40,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#0f0f0f",
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:searchie.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
