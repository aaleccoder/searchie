{
  "name": "google-search",
  "title": "Google Search",
  "description": "Google Search plugin for Searchie.",
  "version": "0.1.0",
  "runtimeEntry": "./dist/runtime.js",
  "commands": [
    {
      "id": "google-search.panel",
      "name": "google search",
      "mode": "panel",
      "entry": "./src/command.tsx",
      "aliases": [
        "google",
        "gsearch",
        "search",
        "rechercher",
        "suchen",
        "cerca",
        "pesquisar"
      ],
      "capabilities": [
        "window.shell"
      ],
      "searchIntegration": {
        "activationMode": "immediate",
        "placeholder": "Search Google...",
        "exitOnEscape": true
      },
      "shortcuts": [
        {
          "keys": "ArrowUp/ArrowDown",
          "description": "Move suggestion selection"
        },
        {
          "keys": "Enter",
          "description": "Open selected suggestion"
        },
        {
          "keys": "Escape",
          "description": "Back to launcher commands"
        }
      ]
    }
  ]
}
